          <span class="cart-item-qty">${item.qty}</span>
          <button class="qty-btn" onclick="changeQty(${item.id},1)">+</button>
          <span class="cart-item-price">$${(item.price*item.qty).toLocaleString('es-AR')}</span>
          <button class="cart-item-remove" onclick="removeFromCart(${item.id})">✕</button>
        </div>
      </div>
    </div>`).join('');
  const total = cart.reduce((s,x)=>s+x.price*x.qty,0);
  document.getElementById('cart-total-price').textContent = `$${total.toLocaleString('es-AR')}`;
}

function toggleCart() {
  document.getElementById('cart-sidebar').classList.toggle('open');
  document.getElementById('cart-overlay').classList.toggle('show');
  renderCart();
}

function checkout() {
  if(cart.length===0) return;
  const wsp = config.whatsapp||'+541100000000';
  const items = cart.map(x=>`${x.brand} ${x.name} x${x.qty} = $${(x.price*x.qty).toLocaleString('es-AR')}`).join('\n');
  const total = cart.reduce((s,x)=>s+x.price*x.qty,0);
  const msg = encodeURIComponent(`Hola! Quiero hacer el siguiente pedido:\n\n${items}\n\nTOTAL: $${total.toLocaleString('es-AR')}`);
  window.open(`https://wa.me/${wsp.replace(/\D/g,'')}?text=${msg}`,'_blank');
}

// ======== REVIEW ========
function setReviewStar(n) { reviewStars=n; updateReviewStars(); }
function updateReviewStars() {
  document.querySelectorAll('#star-select span').forEach((s,i)=>s.classList.toggle('lit',i<reviewStars));
}
function submitReview() {
  const name = document.getElementById('review-name').value.trim();
  const text = document.getElementById('review-text').value.trim();
  if(!name || !text || reviewStars===0) { showToast('Completá todos los campos y elegí una puntuación','error'); return; }
  if(!currentModalProduct) return;
  const p = products.find(x=>x.id===currentModalProduct.id);
  if(!p) return;
  p.reviews = p.reviews||[];
  p.reviews.push({name, text, stars:reviewStars, date:new Date().toLocaleDateString('es-AR')});
  const total = p.reviews.reduce((s,r)=>s+r.stars,0);
  p.rating = Math.round((total/p.reviews.length)*10)/10;
  document.getElementById('modal-rating-text').textContent = `${p.rating}/5 · ${p.reviews.length} reseñas`;
  document.getElementById('modal-stars').innerHTML = getStars(p.rating);
  save(); renderProducts();
  document.getElementById('review-name').value='';
  document.getElementById('review-text').value='';
  reviewStars=0; updateReviewStars();
  showToast('¡Reseña publicada! Gracias 🌸','success');
}

// ======== TOAST ========
function showToast(msg, type='') {
  const t=document.getElementById('toast');
  t.textContent=msg; t.className='toast '+(type||'');
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}

// ======== ADMIN ========
function openAdmin() {
  document.getElementById('admin-login').classList.add('show');
  document.getElementById('admin-pwd').value='';
  document.getElementById('login-error').textContent='';
  setTimeout(()=>document.getElementById('admin-pwd').focus(),300);
}
function closeAdminLogin() { document.getElementById('admin-login').classList.remove('show'); }
function checkAdminPwd() {
  const pwd = document.getElementById('admin-pwd').value;
  if(pwd === config.pwd) {
    closeAdminLogin();
    document.getElementById('admin-panel').classList.add('show');
    refreshAdminData();
  } else {
    document.getElementById('login-error').textContent = 'Contraseña incorrecta';
    document.getElementById('admin-pwd').value='';
  }
}
function closeAdminPanel() { document.getElementById('admin-panel').classList.remove('show'); renderProducts(); }

function switchAdminTab(tab) {
  document.querySelectorAll('.admin-tab').forEach(t=>t.classList.remove('active'));
  event.target.classList.add('active');
  document.querySelectorAll('.admin-section').forEach(s=>s.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  if(tab==='dashboard') updateDashboard();
  if(tab==='productos') renderAdminProducts();
  if(tab==='stock') renderStockTable();
  if(tab==='proveedores') renderProviders();
  if(tab==='nuevo' && editingProductId===null) clearForm();
  if(tab==='config') loadConfig();
}

function refreshAdminData() { updateDashboard(); renderAdminProducts(); renderStockTable(); renderProviders(); loadConfig(); }

function updateDashboard() {
  document.getElementById('stat-productos').textContent = products.length;
  document.getElementById('stat-stock').textContent = products.reduce((s,p)=>s+p.stock,0);
  const margins = products.map(p=>p.margin||0);
  document.getElementById('stat-margen').textContent = Math.round(margins.reduce((a,b)=>a+b,0)/margins.length)+'%';
  document.getElementById('stat-proveedores').textContent = providers.length;
  const alerts = products.filter(p=>p.stock<=config.stockAlert);
  const alertBox = document.getElementById('stock-alerts');
  if(alerts.length===0) { alertBox.innerHTML='<p style="color:var(--success);font-size:0.8rem">✓ Todo el stock en niveles normales</p>'; return; }
  alertBox.innerHTML = alerts.map(p=>`<div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.04)">
    <span style="font-size:0.85rem">${p.emoji} ${p.brand} - ${p.name}</span>
    <span class="tbl-badge ${p.stock===0?'out':'low'}">${p.stock===0?'Sin stock':'Stock: '+p.stock}</span>
  </div>`).join('');
}

function renderAdminProducts() {
  const tbody = document.getElementById('admin-products-body');
  const provSelect = document.getElementById('f-provider');
  provSelect.innerHTML = '<option value="">Sin proveedor</option>' + providers.map((p,i)=>`<option value="${i}">${p.name}</option>`).join('');
  tbody.innerHTML = products.map(p=>{
    const prov = p.provider!==undefined && providers[p.provider] ? providers[p.provider].name : '—';
    const sc = p.stock===0?'out':p.stock<=config.stockAlert?'low':'ok';
    return `<tr>
      <td><div style="font-weight:400;color:var(--white)">${p.emoji} ${p.name}</div><div style="font-size:0.65rem;color:var(--gray)">${p.brand}</div></td>
      <td><span class="tbl-badge ok">${p.type}</span></td>
      <td>$${p.cost.toLocaleString('es-AR')}</td>
      <td>${p.margin}%</td>
      <td style="color:var(--gold)">$${p.price.toLocaleString('es-AR')}</td>
      <td><span class="tbl-badge ${sc}">${p.stock}</span></td>
      <td style="font-size:0.72rem">${prov}</td>
      <td style="display:flex;gap:8px">
        <button class="btn-edit" onclick="editProduct(${p.id})">Editar</button>
        <button class="btn-danger" onclick="deleteProduct(${p.id})">Borrar</button>
      </td>
    </tr>`;
  }).join('');
}

function renderStockTable() {
  const tbody = document.getElementById('stock-table-body');
  tbody.innerHTML = products.map(p=>{
    const sc = p.stock===0?'out':p.stock<=config.stockAlert?'low':'ok';
    return `<tr>
      <td>${p.emoji} ${p.brand} — ${p.name}</td>
      <td><span class="tbl-badge ok">${p.type}</span></td>
      <td><span class="tbl-badge ${sc}">${p.stock}</span></td>
      <td><div style="display:flex;gap:8px;align-items:center">
        <button class="qty-btn" onclick="adjustStock(${p.id},-1)">−</button>
        <input type="number" class="inline-edit" value="${p.stock}" onchange="setStock(${p.id},this.value)" min="0">
        <button class="qty-btn" onclick="adjustStock(${p.id},1)">+</button>
      </div></td>
      <td><span class="tbl-badge ${sc}">${p.stock===0?'Sin stock':p.stock<=config.stockAlert?'Stock bajo':'OK'}</span></td>
    </tr>`;
  }).join('');
}

function adjustStock(id, delta) {
  const p = products.find(x=>x.id===id);
  if(!p) return;
  p.stock = Math.max(0, p.stock+delta);
  save(); renderStockTable(); showToast('Stock actualizado','success');
}
function setStock(id, val) {
  const p = products.find(x=>x.id===id);
  if(!p) return;
  p.stock = Math.max(0, parseInt(val)||0);
  save(); renderStockTable();
}

function calcSalePrice() {
  const cost = parseFloat(document.getElementById('f-cost').value)||0;
  const margin = parseFloat(document.getElementById('f-margin').value)||0;
  const sale = cost * (1 + margin/100);
  document.getElementById('f-sale-price').value = sale > 0 ? Math.round(sale).toLocaleString('es-AR') : '';
  if(cost>0 && margin>0) {
    document.getElementById('calc-preview').style.display='block';
    document.getElementById('cp-cost').textContent='$'+cost.toLocaleString('es-AR');
    document.getElementById('cp-pct').textContent=margin;
    document.getElementById('cp-gain').textContent='$'+(cost*margin/100).toLocaleString('es-AR');
    document.getElementById('cp-sale').textContent='$'+Math.round(sale).toLocaleString('es-AR');
  }
}

function saveProduct() {
  const brand = document.getElementById('f-brand').value.trim();
  const name = document.getElementById('f-name').value.trim();
  if(!brand || !name) { showToast('Completá marca y nombre','error'); return; }
  const cost = parseFloat(document.getElementById('f-cost').value)||0;
  const margin = parseFloat(document.getElementById('f-margin').value)||0;
  const price = Math.round(cost*(1+margin/100));
  const seasons = [...document.querySelectorAll('.f-season:checked')].map(c=>c.value);
  const sizes = document.getElementById('f-sizes').value.split(',').map(s=>parseFloat(s.trim())).filter(Boolean);
  const prov = document.getElementById('f-provider').value;
  const data = {
    brand, name, type:document.getElementById('f-type').value,
    emoji:document.getElementById('f-emoji').value||'🌹',
    cost, margin, price, stock:parseInt(document.getElementById('f-stock').value)||0,
    sizes: sizes.length ? sizes : [50],
    desc:document.getElementById('f-desc').value,
    topNotes:document.getElementById('f-top').value.split(',').map(s=>s.trim()).filter(Boolean),
    heartNotes:document.getElementById('f-heart').value.split(',').map(s=>s.trim()).filter(Boolean),
    baseNotes:document.getElementById('f-base').value.split(',').map(s=>s.trim()).filter(Boolean),
    seasons, fragrantica:document.getElementById('f-fragrantica').value,
    rating:parseFloat(document.getElementById('f-rating').value)||4.5,
    reviews:[], provider:prov!==''?parseInt(prov):undefined
  };
  if(editingProductId !== null) {
    const idx = products.findIndex(x=>x.id===editingProductId);
    data.id = editingProductId; data.reviews = products[idx].reviews||[];
    products[idx] = data;
    editingProductId=null; document.getElementById('form-title').textContent='Nuevo Producto';
    showToast('Producto actualizado ✓','success');
  } else {
    data.id = Date.now();
    products.push(data);
    showToast('Producto agregado ✓','success');
  }
  save(); clearForm(); renderAdminProducts(); renderProducts(); updateDashboard();
}

function editProduct(id) {
  const p = products.find(x=>x.id===id);
  if(!p) return;
  editingProductId=id;
  document.getElementById('form-title').textContent='Editar Producto';
  document.getElementById('f-brand').value=p.brand;
  document.getElementById('f-name').value=p.name;
  document.getElementById('f-type').value=p.type;
  document.getElementById('f-emoji').value=p.emoji||'';
  document.getElementById('f-cost').value=p.cost;
  document.getElementById('f-margin').value=p.margin;
  document.getElementById('f-sale-price').value=p.price.toLocaleString('es-AR');
  document.getElementById('f-stock').value=p.stock;
  document.getElementById('f-sizes').value=(p.sizes||[]).join(',');
  document.getElementById('f-desc').value=p.desc||'';
  document.getElementById('f-top').value=(p.topNotes||[]).join(',');
  document.getElementById('f-heart').value=(p.heartNotes||[]).join(',');
  document.getElementById('f-base').value=(p.baseNotes||[]).join(',');
  document.getElementById('f-fragrantica').value=p.fragrantica||'';
  document.getElementById('f-rating').value=p.rating;
  document.querySelectorAll('.f-season').forEach(c=>{ c.checked=(p.seasons||[]).includes(c.value); });
  if(p.provider!==undefined) document.getElementById('f-provider').value=p.provider;
  calcSalePrice();
  document.querySelectorAll('.admin-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.admin-section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.admin-tab')[2].classList.add('active');
  document.getElementById('tab-nuevo').classList.add('active');
}

function deleteProduct(id) {
  if(!confirm('¿Borrar este producto?')) return;
  products = products.filter(x=>x.id!==id);
  save(); renderAdminProducts(); renderProducts(); updateDashboard();
  showToast('Producto eliminado','success');
}

function clearForm() {
  editingProductId=null;
  document.getElementById('form-title').textContent='Nuevo Producto';
  ['f-brand','f-name','f-emoji','f-cost','f-margin','f-sale-price','f-stock','f-sizes','f-desc','f-top','f-heart','f-base','f-fragrantica','f-rating'].forEach(id=>{ const el=document.getElementById(id); if(el) el.value=''; });
  document.getElementById('f-type').value='caja';
  document.querySelectorAll('.f-season').forEach(c=>c.checked=false);
  document.getElementById('calc-preview').style.display='none';
}

function renderProviders() {
  const plist = document.getElementById('providers-list');
  if(providers.length===0) { plist.innerHTML='<p style="color:var(--gray);font-size:0.85rem">No hay proveedores registrados</p>'; return; }
  plist.innerHTML = `<table class="admin-table"><thead><tr><th>Nombre</th><th>Teléfono</th><th>Instagram</th><th>TikTok</th><th>Web</th><th>Notas</th><th></th></tr></thead><tbody>${
    providers.map((p,i)=>`<tr>
      <td style="font-weight:400;color:var(--white)">${p.name}</td>
      <td><a href="https://wa.me/${(p.phone||'').replace(/\D/g,'')}" target="_blank" class="provider-link">${p.phone||'—'}</a></td>
      <td><a href="https://instagram.com/${(p.instagram||'').replace('@','')}" target="_blank" class="provider-link">${p.instagram||'—'}</a></td>
      <td><a href="https://tiktok.com/@${(p.tiktok||'').replace('@','')}" target="_blank" class="provider-link">${p.tiktok||'—'}</a></td>
      <td>${p.web?`<a href="${p.web}" target="_blank" class="provider-link">Visitar ↗</a>`:'—'}</td>
      <td style="font-size:0.72rem;color:var(--gray)">${p.notes||''}</td>
      <td><button class="btn-danger" onclick="deleteProvider(${i})">Borrar</button></td>
    </tr>`).join('')
  }</tbody></table>`;
  const sel = document.getElementById('f-provider');
  sel.innerHTML='<option value="">Sin proveedor</option>'+providers.map((p,i)=>`<option value="${i}">${p.name}</option>`).join('');
}

function showProviderForm() { document.getElementById('provider-form-box').style.display='block'; }
function hideProviderForm() { document.getElementById('provider-form-box').style.display='none'; }
function saveProvider() {
  const name = document.getElementById('pf-name').value.trim();
  if(!name) { showToast('Ingresá el nombre del proveedor','error'); return; }
  providers.push({ name, phone:document.getElementById('pf-phone').value, instagram:document.getElementById('pf-instagram').value, tiktok:document.getElementById('pf-tiktok').value, web:document.getElementById('pf-web').value, notes:document.getElementById('pf-notes').value });
  save(); renderProviders(); hideProviderForm();
  ['pf-name','pf-phone','pf-instagram','pf-tiktok','pf-web','pf-notes'].forEach(id=>document.getElementById(id).value='');
  showToast('Proveedor agregado ✓','success');
}
function deleteProvider(i) {
  if(!confirm('¿Borrar este proveedor?')) return;
  providers.splice(i,1); save(); renderProviders(); showToast('Proveedor eliminado','success');
}

function loadConfig() {
  document.getElementById('cfg-name').value=config.name||'';
  document.getElementById('cfg-margin').value=config.margin||40;
  document.getElementById('cfg-stock-alert').value=config.stockAlert||3;
  document.getElementById('cfg-wsp').value=config.whatsapp||'';
}
function saveConfig() {
  config.name = document.getElementById('cfg-name').value;
  config.margin = parseInt(document.getElementById('cfg-margin').value)||40;
  config.stockAlert = parseInt(document.getElementById('cfg-stock-alert').value)||3;
  config.whatsapp = document.getElementById('cfg-wsp').value;
  const newPwd = document.getElementById('cfg-pwd').value;
  if(newPwd) config.pwd=newPwd;
  save(); updateDashboard(); showToast('Configuración guardada ✓','success');
}

function openWhatsApp() {
  const wsp = config.whatsapp||'+541100000000';
  window.open(`https://wa.me/${wsp.replace(/\D/g,'')}?text=Hola! Quiero consultar sobre un perfume 🌹`,'_blank');
}
</script>
