// ======== CART ========
function addToCart(id) {
  const p = products.find(x=>x.id===id);
  if(!p || p.stock===0) { showToast('Sin stock disponible', 'error'); return; }
  const existing = cart.find(x=>x.id===id);
  if(existing) existing.qty++;
  else cart.push({id, name:p.name, brand:p.brand, price:p.price, emoji:p.emoji||'🌹', type:p.type, qty:1});
  updateCartCount();
  showToast(`${p.name} agregado al carrito ✓`, 'success');
}

function removeFromCart(id) { cart = cart.filter(x=>x.id!==id); updateCartCount(); renderCart(); }
function changeQty(id, delta) {
  const item = cart.find(x=>x.id===id);
  if(!item) return;
  item.qty += delta;
  if(item.qty <= 0) removeFromCart(id);
  else { updateCartCount(); renderCart(); }
}

function updateCartCount() {
  const total = cart.reduce((s,x)=>s+x.qty,0);
  document.getElementById('cart-count').textContent = total;
}

