      <div class="product-info">
        <div class="product-brand">${p.brand}</div>
        <div class="product-name">${p.name}</div>
        <div class="product-stars">${getStars(p.rating)}<span class="rating-num">${p.rating}/5</span></div>
        <div class="product-season">${(p.seasons||[]).map(s=>`<span class="season-tag ${s}">${s.charAt(0).toUpperCase()+s.slice(1)}</span>`).join('')}</div>
