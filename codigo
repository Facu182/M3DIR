<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AURA — Perfumería de Lujo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C9A96E;
    --gold-light: #E8D5B0;
    --gold-dark: #8B6914;
    --black: #0A0A0A;
    --dark: #141414;
    --dark2: #1E1E1E;
    --dark3: #2A2A2A;
    --dark4: #383838;
    --gray: #888;
    --gray-light: #CCC;
    --white: #F5F0E8;
    --white2: #FAF7F2;
    --accent: #C9A96E;
    --danger: #C0392B;
    --success: #27AE60;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { background: var(--black); color: var(--white); font-family: 'Jost', sans-serif; font-weight: 300; overflow-x: hidden; }
  
  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--dark); }
  ::-webkit-scrollbar-thumb { background: var(--gold-dark); border-radius: 2px; }

  /* LOADING */
  #loader { position: fixed; inset: 0; background: var(--black); z-index: 9999; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 20px; transition: opacity 0.8s; }
  #loader .logo-load { font-family: 'Cormorant Garamond', serif; font-size: 4rem; letter-spacing: 0.5em; color: var(--gold); animation: pulse 1.5s infinite; }
  #loader .bar { width: 200px; height: 1px; background: var(--dark3); position: relative; overflow: hidden; }
  #loader .bar::after { content: ''; position: absolute; inset: 0; background: var(--gold); transform: translateX(-100%); animation: load 1.5s ease-in-out forwards; }
  @keyframes load { to { transform: translateX(0); } }
  @keyframes pulse { 0%,100% { opacity: 0.6; } 50% { opacity: 1; } }

  /* NAV */
  nav { position: fixed; top: 0; width: 100%; z-index: 100; padding: 20px 60px; display: flex; align-items: center; justify-content: space-between; transition: all 0.4s; }
  nav.scrolled { background: rgba(10,10,10,0.95); backdrop-filter: blur(20px); padding: 14px 60px; border-bottom: 1px solid rgba(201,169,110,0.15); }
  .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; letter-spacing: 0.4em; color: var(--gold); text-decoration: none; }
  .nav-links { display: flex; gap: 40px; list-style: none; }
  .nav-links a { color: var(--gray-light); text-decoration: none; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; transition: color 0.3s; }
  .nav-links a:hover { color: var(--gold); }
  .nav-actions { display: flex; gap: 20px; align-items: center; }
  .nav-btn { background: none; border: 1px solid rgba(201,169,110,0.4); color: var(--gold); padding: 8px 20px; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; transition: all 0.3s; font-family: 'Jost', sans-serif; }
  .nav-btn:hover { background: var(--gold); color: var(--black); }
  .cart-icon { position: relative; cursor: pointer; color: var(--gold-light); font-size: 1.1rem; }
  .cart-count { position: absolute; top: -8px; right: -8px; background: var(--gold); color: var(--black); font-size: 0.6rem; font-weight: 600; width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }

  /* HERO */
  #hero { height: 100vh; position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 50%, rgba(201,169,110,0.08) 0%, transparent 60%), radial-gradient(ellipse at 70% 20%, rgba(201,169,110,0.05) 0%, transparent 50%); }
  .hero-lines { position: absolute; inset: 0; overflow: hidden; }
  .hero-lines::before { content: ''; position: absolute; top: 50%; left: -10%; width: 120%; height: 1px; background: linear-gradient(90deg, transparent, rgba(201,169,110,0.2), transparent); transform: translateY(-50%); }
  .hero-content { text-align: center; z-index: 1; animation: fadeUp 1.2s ease 0.5s both; }
  .hero-eyebrow { font-size: 0.65rem; letter-spacing: 0.5em; text-transform: uppercase; color: var(--gold); margin-bottom: 30px; }
  .hero-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(5rem, 12vw, 10rem); font-weight: 300; line-height: 0.9; color: var(--white); margin-bottom: 20px; }
  .hero-title em { color: var(--gold); font-style: italic; }
  .hero-subtitle { font-size: 0.8rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gray); margin-bottom: 50px; }
  .hero-ctas { display: flex; gap: 20px; justify-content: center; }
  .btn-primary { background: var(--gold); color: var(--black); padding: 14px 40px; font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; border: none; cursor: pointer; transition: all 0.3s; font-family: 'Jost', sans-serif; font-weight: 500; }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }
  .btn-outline { background: none; color: var(--gold-light); padding: 14px 40px; font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; border: 1px solid rgba(201,169,110,0.4); cursor: pointer; transition: all 0.3s; font-family: 'Jost', sans-serif; }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }
  .hero-scroll { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 10px; color: var(--gray); font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase; animation: bounce 2s infinite; }
  .scroll-line { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--gold), transparent); }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes bounce { 0%,100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(8px); } }

  /* SECTIONS */
  section { padding: 100px 60px; }
  .section-header { text-align: center; margin-bottom: 70px; }
  .section-label { font-size: 0.6rem; letter-spacing: 0.5em; text-transform: uppercase; color: var(--gold); margin-bottom: 16px; display: block; }
  .section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 300; color: var(--white); }
  .section-title em { color: var(--gold); font-style: italic; }
  .section-line { width: 60px; height: 1px; background: var(--gold); margin: 24px auto 0; }

  /* CATEGORIES STRIP */
  #categories { padding: 40px 60px; border-top: 1px solid rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05); }
  .cat-strip { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .cat-pill { background: none; border: 1px solid rgba(201,169,110,0.25); color: var(--gray-light); padding: 10px 24px; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; transition: all 0.3s; font-family: 'Jost', sans-serif; border-radius: 0; }
  .cat-pill:hover, .cat-pill.active { background: rgba(201,169,110,0.1); border-color: var(--gold); color: var(--gold); }

  /* PRODUCT GRID */
  #catalogo { background: var(--dark); }
  .search-bar { display: flex; gap: 12px; margin-bottom: 50px; max-width: 500px; margin-left: auto; margin-right: auto; }
  .search-input { flex: 1; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: var(--white); padding: 12px 20px; font-size: 0.8rem; font-family: 'Jost', sans-serif; outline: none; transition: border-color 0.3s; }
  .search-input:focus { border-color: var(--gold); }
  .search-input::placeholder { color: var(--gray); }
  .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2px; }
  .product-card { background: var(--dark2); position: relative; overflow: hidden; cursor: pointer; transition: transform 0.4s; }
  .product-card:hover { transform: translateY(-4px); }
  .product-card:hover .product-overlay { opacity: 1; }
  .product-img { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; transition: transform 0.6s; background: var(--dark3); position: relative; overflow: hidden; }
  .product-img-placeholder { width: 100%; aspect-ratio: 3/4; background: var(--dark3); display: flex; align-items: center; justify-content: center; font-size: 4rem; transition: transform 0.6s; }
  .product-card:hover .product-img-placeholder { transform: scale(1.04); }
  .product-overlay { position: absolute; inset: 0; background: rgba(10,10,10,0.7); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.4s; gap: 12px; }
  .badge-type { position: absolute; top: 16px; left: 16px; background: var(--gold); color: var(--black); font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 4px 10px; font-weight: 500; }
  .badge-combo { background: #8B3A8B; color: #fff; }
  .badge-decant { background: var(--dark3); color: var(--gold); border: 1px solid var(--gold); }
  .product-info { padding: 20px; border-top: 1px solid rgba(255,255,255,0.05); }
  .product-brand { font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
  .product-name { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 400; color: var(--white); margin-bottom: 8px; }
  .product-stars { display: flex; gap: 3px; align-items: center; margin-bottom: 8px; }
  .star { font-size: 0.7rem; color: var(--gold); }
  .star.empty { color: var(--dark4); }
  .rating-num { font-size: 0.7rem; color: var(--gray); margin-left: 6px; }
  .product-season { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; }
  .season-tag { font-size: 0.55rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 3px 8px; border: 1px solid rgba(255,255,255,0.1); color: var(--gray); }
  .season-tag.verano { border-color: rgba(239,168,39,0.4); color: #EFA827; }
  .season-tag.invierno { border-color: rgba(100,149,237,0.4); color: #6495ED; }
  .season-tag.noche { border-color: rgba(148,0,211,0.4); color: #9400D3; }
  .season-tag.primavera { border-color: rgba(100,200,100,0.4); color: #64C864; }
  .season-tag.calor { border-color: rgba(255,80,0,0.4); color: #FF5000; }
  .product-price { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 400; color: var(--gold); }
  .product-price-old { font-size: 0.8rem; color: var(--gray); text-decoration: line-through; margin-left: 8px; }
  .stock-badge { font-size: 0.6rem; letter-spacing: 0.1em; color: var(--success); margin-top: 4px; }
  .stock-low { color: #F39C12; }
  .stock-out { color: var(--danger); }
  .btn-add { background: var(--gold); color: var(--black); border: none; padding: 10px 24px; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; font-family: 'Jost', sans-serif; font-weight: 500; transition: all 0.3s; }
  .btn-add:hover { background: var(--gold-light); }
  .btn-detail { background: none; color: var(--white); border: 1px solid rgba(255,255,255,0.3); padding: 10px 24px; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; font-family: 'Jost', sans-serif; transition: all 0.3s; }
  .btn-detail:hover { border-color: var(--gold); color: var(--gold); }

  /* FEATURED BANNER */
  #destacado { background: var(--black); padding: 100px 60px; }
  .featured-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; max-width: 1200px; margin: 0 auto; }
  .featured-img { aspect-ratio: 3/4; background: var(--dark2); display: flex; align-items: center; justify-content: center; font-size: 8rem; position: relative; overflow: hidden; }
  .featured-img::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at center, rgba(201,169,110,0.1), transparent); }
  .featured-text { padding: 20px 0; }
  .featured-fragrance { font-family: 'Cormorant Garamond', serif; font-size: clamp(3rem, 5vw, 5rem); font-weight: 300; line-height: 1; margin-bottom: 24px; }
  .featured-notes { margin-bottom: 32px; }
  .note-group { margin-bottom: 12px; display: flex; gap: 12px; align-items: flex-start; }
  .note-label { font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); min-width: 80px; padding-top: 2px; }
  .note-list { font-size: 0.8rem; color: var(--gray-light); }
  .fragrantica-link { display: inline-flex; align-items: center; gap: 8px; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); border-bottom: 1px solid rgba(201,169,110,0.3); padding-bottom: 2px; cursor: pointer; transition: all 0.3s; margin-top: 8px; margin-bottom: 24px; background: none; border-top: none; border-left: none; border-right: none; font-family: 'Jost', sans-serif; }
  .fragrantica-link:hover { color: var(--gold-light); border-bottom-color: var(--gold); }

  /* TESTIMONIALS / RATINGS */
  #ratings { background: var(--dark); }
  .ratings-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
  .rating-card { background: var(--dark2); padding: 32px; }
  .rating-header { display: flex; gap: 12px; align-items: center; margin-bottom: 16px; }
  .avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--dark3); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; border: 1px solid rgba(201,169,110,0.2); }
  .reviewer-name { font-size: 0.85rem; font-weight: 400; }
  .reviewer-date { font-size: 0.65rem; color: var(--gray); }
  .review-text { font-size: 0.85rem; color: var(--gray-light); line-height: 1.7; font-style: italic; }
  .review-perfume { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-top: 12px; }

  /* CART SIDEBAR */
  #cart-sidebar { position: fixed; right: -420px; top: 0; height: 100vh; width: 420px; background: var(--dark); border-left: 1px solid rgba(201,169,110,0.15); z-index: 200; transition: right 0.4s cubic-bezier(0.4,0,0.2,1); display: flex; flex-direction: column; overflow: hidden; }
  #cart-sidebar.open { right: 0; }
  .cart-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 199; opacity: 0; pointer-events: none; transition: opacity 0.4s; }
  .cart-overlay.show { opacity: 1; pointer-events: all; }
  .cart-header { padding: 30px; border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; justify-content: space-between; align-items: center; }
  .cart-title { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; color: var(--white); }
  .cart-close { background: none; border: none; color: var(--gray); font-size: 1.2rem; cursor: pointer; transition: color 0.3s; }
  .cart-close:hover { color: var(--gold); }
  .cart-items { flex: 1; overflow-y: auto; padding: 20px 30px; }
  .cart-item { display: flex; gap: 16px; padding: 16px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
  .cart-item-img { width: 60px; height: 80px; background: var(--dark3); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; flex-shrink: 0; }
  .cart-item-info { flex: 1; }
  .cart-item-name { font-family: 'Cormorant Garamond', serif; font-size: 1rem; margin-bottom: 4px; }
  .cart-item-type { font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
  .cart-item-controls { display: flex; align-items: center; gap: 12px; }
  .qty-btn { background: none; border: 1px solid rgba(255,255,255,0.15); color: var(--white); width: 24px; height: 24px; cursor: pointer; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
  .qty-btn:hover { border-color: var(--gold); color: var(--gold); }
  .cart-item-qty { font-size: 0.85rem; min-width: 20px; text-align: center; }
  .cart-item-price { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; color: var(--gold); }
  .cart-item-remove { background: none; border: none; color: var(--gray); cursor: pointer; font-size: 0.8rem; transition: color 0.3s; }
  .cart-item-remove:hover { color: var(--danger); }
  .cart-footer { padding: 24px 30px; border-top: 1px solid rgba(255,255,255,0.06); }
  .cart-total { display: flex; justify-content: space-between; margin-bottom: 20px; }
  .cart-total-label { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gray); }
  .cart-total-price { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; color: var(--gold); }
  .btn-checkout { width: 100%; background: var(--gold); color: var(--black); border: none; padding: 16px; font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; cursor: pointer; font-family: 'Jost', sans-serif; font-weight: 500; transition: all 0.3s; }
  .btn-checkout:hover { background: var(--gold-light); }

  /* PRODUCT MODAL */
  #product-modal { position: fixed; inset: 0; z-index: 300; display: none; align-items: center; justify-content: center; padding: 40px; background: rgba(0,0,0,0.85); }
  #product-modal.show { display: flex; }
  .modal-inner { background: var(--dark); max-width: 900px; width: 100%; max-height: 90vh; overflow-y: auto; position: relative; display: grid; grid-template-columns: 1fr 1fr; }
  .modal-img { aspect-ratio: 3/4; background: var(--dark2); display: flex; align-items: center; justify-content: center; font-size: 8rem; }
  .modal-content { padding: 40px; overflow-y: auto; }
  .modal-close { position: absolute; top: 16px; right: 16px; background: none; border: none; color: var(--gray); font-size: 1.4rem; cursor: pointer; z-index: 1; transition: color 0.3s; }
  .modal-close:hover { color: var(--gold); }
  .modal-brand { font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; }
  .modal-name { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 300; margin-bottom: 16px; }
  .modal-rating-row { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
  .modal-price { font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--gold); margin-bottom: 24px; }
  .modal-divider { border: none; border-top: 1px solid rgba(255,255,255,0.06); margin: 20px 0; }
  .modal-section-title { font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
  .notes-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 8px; }
  .note-chip { background: rgba(201,169,110,0.08); border: 1px solid rgba(201,169,110,0.2); color: var(--gold-light); font-size: 0.7rem; padding: 4px 10px; }
  .modal-desc { font-size: 0.85rem; color: var(--gray-light); line-height: 1.8; margin-bottom: 20px; }
  .modal-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; }
  .modal-select { width: 100%; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: var(--white); padding: 12px 16px; font-size: 0.8rem; font-family: 'Jost', sans-serif; outline: none; margin-bottom: 16px; cursor: pointer; appearance: none; }
  .modal-select option { background: var(--dark); }
  .review-form { margin-top: 24px; }
  .review-form input, .review-form textarea { width: 100%; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: var(--white); padding: 10px 14px; font-size: 0.8rem; font-family: 'Jost', sans-serif; outline: none; margin-bottom: 10px; transition: border-color 0.3s; }
  .review-form input:focus, .review-form textarea:focus { border-color: var(--gold); }
  .review-form textarea { resize: vertical; min-height: 80px; }
  .star-select { display: flex; gap: 8px; margin-bottom: 10px; }
  .star-select span { font-size: 1.2rem; cursor: pointer; color: var(--dark4); transition: color 0.2s; }
  .star-select span.lit { color: var(--gold); }

  /* ADMIN PANEL */
  #admin-panel { display: none; position: fixed; inset: 0; z-index: 500; background: #0D0D0D; overflow-y: auto; }
  #admin-panel.show { display: block; }
  .admin-nav { background: #111; border-bottom: 1px solid rgba(201,169,110,0.15); padding: 16px 40px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 10; }
  .admin-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--gold); letter-spacing: 0.3em; }
  .admin-logo span { font-size: 0.6rem; letter-spacing: 0.2em; display: block; color: var(--gray); font-family: 'Jost', sans-serif; text-transform: uppercase; }
  .admin-exit { background: none; border: 1px solid rgba(255,255,255,0.15); color: var(--gray-light); padding: 8px 20px; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; font-family: 'Jost', sans-serif; transition: all 0.3s; }
  .admin-exit:hover { border-color: var(--gold); color: var(--gold); }
  .admin-tabs { display: flex; gap: 0; padding: 0 40px; background: #111; border-bottom: 1px solid rgba(255,255,255,0.05); overflow-x: auto; }
  .admin-tab { padding: 14px 24px; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; color: var(--gray); border-bottom: 2px solid transparent; transition: all 0.3s; background: none; border-top: none; border-left: none; border-right: none; font-family: 'Jost', sans-serif; white-space: nowrap; }
  .admin-tab.active, .admin-tab:hover { color: var(--gold); border-bottom-color: var(--gold); }
  .admin-content { padding: 40px; }
  .admin-section { display: none; }
  .admin-section.active { display: block; }
  .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
  .admin-title { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--white); }
  .admin-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 40px; }
  .admin-stat { background: #161616; border: 1px solid rgba(255,255,255,0.06); padding: 24px; }
