}

function searchProducts() {
  const q = document.getElementById('search-input').value.toLowerCase();
  if(!q) { renderProducts(); return; }
  const res = products.filter(p =>
    p.name.toLowerCase().includes(q) || p.brand.toLowerCase().includes(q) ||
    (p.topNotes||[]).some(n=>n.toLowerCase().includes(q)) ||
    (p.heartNotes||[]).some(n=>n.toLowerCase().includes(q)) ||
    (p.baseNotes||[]).some(n=>n.toLowerCase().includes(q))
  );
  renderProducts(res);
}

function sortProducts(by) {
  const ps = [...products];
  if(by==='price-asc') ps.sort((a,b)=>a.price-b.price);
  else if(by==='price-desc') ps.sort((a,b)=>b.price-a.price);
  else if(by==='rating') ps.sort((a,b)=>b.rating-a.rating);
  else if(by==='name') ps.sort((a,b)=>a.name.localeCompare(b.name));
  renderProducts(ps);
}

