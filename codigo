function getStars(r) {
  let s=''; for(let i=1;i<=5;i++) s+=`<span class="star ${i<=Math.round(r)?'':'empty'}">★</span>`; return s;
}

function renderProducts(list) {
  const ps = list || products;
  const grid = document.getElementById('product-grid');
  const nr = document.getElementById('no-results');
  let visible = ps.filter(p => {
    if(currentFilter !== 'all' && p.type !== currentFilter) return false;
    if(currentSeason && !p.seasons.includes(currentSeason)) return false;
    return true;
  });
  if(visible.length === 0) { grid.innerHTML=''; nr.style.display='block'; return; }
  nr.style.display='none';
  grid.innerHTML = visible.map(p => {
    const provider = p.provider !== undefined ? providers[p.provider] : null;
    const stockClass = p.stock === 0 ? 'stock-out' : p.stock <= config.stockAlert ? 'stock-low' : '';
    const stockText = p.stock === 0 ? '✕ Sin stock' : p.stock <= config.stockAlert ? `⚠ Últimas ${p.stock} unidades` : `✓ Disponible`;
    const badgeType = p.type === 'combo' ? 'combo' : p.type === 'decanta' ? 'decant' : '';
    const badgeLabel = p.type === 'caja' ? 'Caja' : p.type === 'decanta' ? 'Decanta' : 'Combo';
    return `<div class="product-card" data-id="${p.id}">
      <div class="product-img-placeholder">${p.emoji||'🌹'}</div>
      <span class="badge-type ${badgeType}">${badgeLabel}</span>
